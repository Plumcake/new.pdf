%PDF-1.7
% Clean Write Test - No response() - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

        app.alert("step 1: starting write tests");

        // === METADATA WRITES ===
        try {
          this.info.Title = "PWNED_TITLE";
          app.alert("title: " + this.info.Title);
        } catch(e) { app.alert("title err: " + e); }

        try {
          this.info.Subject = "PWNED_SUBJECT";
          app.alert("subject: " + this.info.Subject);
        } catch(e) { app.alert("subject err: " + e); }

        try {
          this.info.Author = "PWNED_AUTHOR";
          app.alert("author: " + this.info.Author);
        } catch(e) { app.alert("author err: " + e); }

        try {
          this.info.Keywords = "PWNED_KEYWORDS";
          app.alert("keywords: " + this.info.Keywords);
        } catch(e) { app.alert("keywords err: " + e); }

        // === FORM FIELD WRITE ===
        try {
          var f = this.addField("exfil", "text", 0, [0,0,1,1]);
          f.value = "PWNED_FIELD";
          app.alert("addField value: " + f.value);
        } catch(e) { app.alert("addField err: " + e); }

        // === BTOA ===
        try {
          var b = btoa("PWNED_DATA");
          app.alert("btoa: " + b);
        } catch(e) { app.alert("btoa err: " + e); }

        // === SETТIMEOUT WRITE AFTER DELAY ===
        try {
          app.setTimeOut(
            "this.info.Title = 'DELAYED_WRITE'; app.alert('delayed title: ' + this.info.Title);",
            500
          );
          app.alert("setTimeout write: queued");
        } catch(e) { app.alert("setTimeout err: " + e); }

        app.alert("all done");

   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
   /Resources 
     /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >>
   >>
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Clean Write Test) Tj ET
BT /F1 12 Tf 50 220 Td (Watch each popup) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000001600 00000 n 
0000001760 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
1850
%%EOF