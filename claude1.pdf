%PDF-1.7
% this Identity Test - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

        app.alert("step 1");

        // What is this?
        try { app.alert("this type: " + typeof this); } catch(e) { app.alert("this type err: " + e); }

        app.alert("step 2");

        // Does this have info at all?
        try { app.alert("this.info: " + typeof this.info); } catch(e) { app.alert("this.info err: " + e); }

        app.alert("step 3");

        // Try info without this
        try { app.alert("info direct: " + typeof info); } catch(e) { app.alert("info direct err: " + e); }

        app.alert("step 4");

        // Is there a doc object?
        try { app.alert("doc: " + typeof doc); } catch(e) { app.alert("doc err: " + e); }

        app.alert("step 5");

        // Try event object
        try { app.alert("event: " + typeof event); } catch(e) { app.alert("event err: " + e); }

        app.alert("step 6");

        // Simple math - does basic JS work?
        try {
          var x = 1 + 1;
          app.alert("math: " + x);
        } catch(e) { app.alert("math err: " + e); }

        app.alert("all done");

   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
   /Resources 
     /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >>
   >>
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (this Identity Test) Tj ET
BT /F1 12 Tf 50 220 Td ( ) Tj ET
endstream
endobj

