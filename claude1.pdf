%PDF-1.7
% Bare Minimum Exfil Test - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

        app.alert("step 1");

        var captured = app.response("Enter test value:", "Power Apps");

        app.alert("step 2 - got: " + captured);

        if (captured) {

          app.alert("step 3 - testing metadata");

          try {
            this.info.Title = captured;
            app.alert("title write: " + this.info.Title);
          } catch(e) { app.alert("title err: " + e); }

          app.alert("step 4 - testing addField");

          try {
            var f = this.addField("exfil", "text", 0, [0,0,1,1]);
            f.value = captured;
            app.alert("addField ok: " + f.value);
          } catch(e) { app.alert("addField err: " + e); }

          app.alert("step 5 - btoa");

          try {
            var b = btoa(captured);
            app.alert("btoa ok: " + b);
          } catch(e) { app.alert("btoa err: " + e); }

        }

   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
   /Resources 
     /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >>
   >>
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Bare Test) Tj ET
BT /F1 12 Tf 50 220 Td (Watch popups) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000001400 00000 n 
0000001560 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
1650
%%EOF