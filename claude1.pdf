%PDF-1.4
1 0 obj
<< /Type /Catalog /Pages 2 0 R /OpenAction 3 0 R >>
endobj

2 0 obj
<< /Type /Pages /Kids [4 0 R] /Count 1 >>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

     try {
       var results = [];

       // ── 1. ENGINE FINGERPRINT ──────────────────────────
       results.push("=== ENGINE ===");
       try { results.push("typeof window: " + typeof window); }
       catch(e) { results.push("window: " + e); }
       try { results.push("typeof document: " + typeof document); }
       catch(e) { results.push("document: " + e); }
       try { results.push("typeof fetch: " + typeof fetch); }
       catch(e) { results.push("fetch: " + e); }
       try { results.push("typeof XMLHttpRequest: " + typeof XMLHttpRequest); }
       catch(e) { results.push("XHR: " + e); }
       try { results.push("viewerVersion: " + app.viewerVersion); }
       catch(e) { results.push("viewerVersion: " + e); }

       // ── 2. LOCATION / ORIGIN ───────────────────────────
       results.push("=== LOCATION ===");
       try { results.push("href: " + window.location.href); }
       catch(e) { results.push("href: " + e); }
       try { results.push("origin: " + window.location.origin); }
       catch(e) { results.push("origin: " + e); }
       try { results.push("protocol: " + window.location.protocol); }
       catch(e) { results.push("protocol: " + e); }

       // ── 3. iOS WEBKIT BRIDGE ───────────────────────────
       results.push("=== WEBKIT ===");
       try {
         results.push("webkit: " + typeof window.webkit);
         results.push("messageHandlers: " + 
           typeof window.webkit.messageHandlers);
         var handlers = Object.getOwnPropertyNames(
           window.webkit.messageHandlers);
         results.push("handlers: " + handlers.join(', '));
       } catch(e) { results.push("webkit: " + e); }

       // ── 4. APP OBJECT SHIM ─────────────────────────────
       results.push("=== APP SHIM ===");
       try {
         var appKeys = [];
         for (var key in app) {
           appKeys.push(key + ':' + typeof app[key]);
         }
         results.push(appKeys.length 
           ? appKeys.join('\n') 
           : "no enumerable keys");
       } catch(e) { results.push("app enum: " + e); }

       // ── 5. WINDOW OBJECT BRIDGES ───────────────────────
       results.push("=== WINDOW BRIDGES ===");
       try {
         var standard = new Set([
           'window','self','document','location','navigator',
           'history','screen','console','performance','crypto',
           'setTimeout','setInterval','clearTimeout','clearInterval',
           'fetch','XMLHttpRequest','WebSocket','Worker',
           'addEventListener','removeEventListener','dispatchEvent',
           'postMessage','close','focus','blur','print',
           'alert','confirm','prompt','requestAnimationFrame',
           'cancelAnimationFrame','getComputedStyle','matchMedia',
           'ResizeObserver','MutationObserver','IntersectionObserver',
           'Promise','Proxy','Reflect','Symbol','Map','Set','WeakMap',
           'Int8Array','Uint8Array','Float32Array','Float64Array',
           'ArrayBuffer','DataView','Blob','File','FileReader',
           'URL','URLSearchParams','FormData','Headers','Request',
           'Response','ReadableStream','WritableStream',
           'TextEncoder','TextDecoder','atob','btoa',
           'indexedDB','localStorage','sessionStorage','caches',
           'open','opener','parent','top','frames','length',
           'name','status','closed','devicePixelRatio',
           'innerWidth','innerHeight','outerWidth','outerHeight',
           'scrollX','scrollY','pageXOffset','pageYOffset',
           'origin','isSecureContext','crossOriginIsolated'
         ]);
         var bridges = Object.getOwnPropertyNames(window)
           .filter(function(k) {
             try {
               return !standard.has(k) &&
                 typeof window[k] === 'object' &&
                 window[k] !== null;
             } catch(e) { return false; }
           });
         results.push(bridges.length 
           ? bridges.join(', ') 
           : "none found");
       } catch(e) { results.push("window enum: " + e); }

       // ── 6. POWERAPPS SPECIFIC BRIDGES ─────────────────
       results.push("=== PA BRIDGES ===");
       try {
         var paNames = [
           'PowerAppsNativeHost','PAHost','AppMagicNative',
           'NativeInterface','AndroidBridge','CanvasHost',
           'PCFHost','FluentHost','MicrosoftHost','MAMHost',
           'IntuneHost','TeamsHost','OfficeHost','MSALHost'
         ];
         var found = paNames.filter(function(n) {
           try { return typeof window[n] !== 'undefined'; }
           catch(e) { return false; }
         });
         results.push(found.length 
           ? found.join(', ') 
           : "none found");
       } catch(e) { results.push("PA bridges: " + e); }

       // ── 7. FRAME CONTEXT ──────────────────────────────
       results.push("=== FRAME ===");
       try {
         results.push("is top: " + (window === window.top));
         results.push("has parent: " + (window.parent !== window));
       } catch(e) { results.push("frame: " + e); }

       // ── 8. INTENT / DEEPLINK PROBE ────────────────────
       results.push("=== INTENTS ===");
       try {
         var intentTest = document.createElement('a');
         intentTest.href = 'intent://probe#Intent;scheme=probe;end';
         results.push("intent href set: " + intentTest.href);
       } catch(e) { results.push("intent: " + e); }

       // ── FINAL OUTPUT ──────────────────────────────────
       app.alert(results.join('\n'));

     } catch(e) {
       app.alert("OUTER ERROR: " + e);
     }

   )
>>
endobj

4 0 obj

  /Type /Page
  /Parent 2 0 R
  /MediaBox [0 0 612 792]
  /Contents 5 0 R
  /Resources << /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >> >>
>>
endobj

