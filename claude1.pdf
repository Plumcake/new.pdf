3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

        // No try/catch - let errors surface
        app.alert("Step 1: running");

        // Test execDialog exists
        app.alert("execDialog type: " + typeof app.execDialog);

        // Try minimal execDialog - simplest possible
        var oDlg = {
          description: {
            name: "Test",
            elements: [
              { type: "static_text", name: "Hello" },
              { type: "ok_cancel" }
            ]
          }
        };

        var r = app.execDialog(oDlg);
        app.alert("execDialog result: " + r);

   )
>>
endobj

