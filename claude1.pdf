%PDF-1.7
% Silent Fail Diagnosis - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

        // === STEP 1: BASIC ALERT FIRST ===
        app.alert("Step 1: JS is running");

        // === STEP 2: TEST RESPONSE ALONE ===
        var e = app.response({
          cQuestion: "Test email field",
          cTitle: "Power Apps",
          cDefault: ""
        });

        app.alert("Step 2: response returned: " + typeof e + " val: " + e);

        // === STEP 3: CONDITIONAL ONLY IF STEP 2 WORKED ===
        if (e !== null && typeof e !== "undefined") {
          var p = app.response({
            cQuestion: "Test password field for: " + e,
            cTitle: "Power Apps",
            cDefault: ""
          });
          app.alert("Step 3: password returned: " + typeof p);
        } else {
          app.alert("Step 3: skipped - email was null or undefined");
        }

   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
   /Resources 
     /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >>
   >>
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Diagnosis Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Watch each step) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000001800 00000 n 
0000001960 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2050
