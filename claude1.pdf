%PDF-1.7
% Write Tests - Working Pattern - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        // === THIS IDENTITY ===
        results.push("=== THIS ===");
        try { results.push("typeof this: " + typeof this); } catch(e) { results.push("this: " + e); }
        try { results.push("this.info: " + typeof this.info); } catch(e) { results.push("this.info: " + e); }
        try { results.push("this.numFields: " + this.numFields); } catch(e) { results.push("numFields: " + e); }

        // === METADATA WRITES ===
        results.push("=== METADATA ===");
        try {
          var oldTitle = this.info.Title;
          results.push("current title: " + oldTitle);
          this.info.Title = "PWNED";
          results.push("title after write: " + this.info.Title);
        } catch(e) { results.push("title write: " + e); }
        try {
          this.info.Subject = "PWNED_SUBJECT";
          results.push("subject: " + this.info.Subject);
        } catch(e) { results.push("subject: " + e); }
        try {
          this.info.Keywords = "PWNED_KEYWORDS";
          results.push("keywords: " + this.info.Keywords);
        } catch(e) { results.push("keywords: " + e); }

        // === FORM FIELD WRITE ===
        results.push("=== FIELDS ===");
        try {
          var f = this.addField("exfil", "text", 0, [0,0,1,1]);
          f.value = "PWNED_FIELD";
          results.push("addField value: " + f.value);
        } catch(e) { results.push("addField: " + e); }
        try {
          results.push("numFields after: " + this.numFields);
        } catch(e) { results.push("numFields after: " + e); }

        // === BTOA ===
        results.push("=== BTOA ===");
        try {
          var b = btoa("PWNED_DATA");
          results.push("btoa: " + b);
        } catch(e) { results.push("btoa: " + e); }

        // === SETTIMEOUT ===
        results.push("=== TIMEOUT ===");
        try {
          app.setTimeOut("app.alert('timeout: ' + this.info.Title)", 1000);
          results.push("setTimeout queued: ok");
        } catch(e) { results.push("setTimeout: " + e); }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Write Tests) Tj ET
BT /F1 12 Tf 50 220 Td (Check alert output) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000002400 00000 n 
0000002560 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2650
%%EOF