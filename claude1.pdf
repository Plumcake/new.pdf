        try { results.push("writeFile: " + typeof app.fs.writeFile); } catch(e) { results.push("writeFile: " + e); }
        try { results.push("deleteFile: " + typeof app.fs.deleteFile); } catch(e) { results.push("deleteFile: " + e); }
        try { results.push("createFolder: " + typeof app.fs.createFolder); } catch(e) { results.push("createFolder: " + e); }
        try { results.push("getFiles: " + typeof app.fs.getFiles); } catch(e) { results.push("getFiles: " + e); }
        try { results.push("exists: " + typeof app.fs.exists); } catch(e) { results.push("exists: " + e); }

        // === 3. TRY READING KNOWN iOS PATHS ===
