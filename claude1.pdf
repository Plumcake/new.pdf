%PDF-1.7
% Minimal Input + Alert Test - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj
2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj
3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (
      try {
        var resp = app.response({
          cQuestion: "Enter any text here - it will be shown in the next popup",
          cTitle: "Test Input",
          cDefault: "Hello from Power Apps PDF"
        });

        if (resp != null) {
          app.alert("You entered:\n\n" + resp + "\n\nIf you see this, JavaScript + input still works!");
        } else {
          app.alert("You cancelled the input.");
        }
      } catch(e) {
        app.alert("Error: " + e);
      }
   )
>>
endobj
4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
>>
endobj
5 0 obj
<< /Length 80 >>
stream
BT /F1 14 Tf 50 250 Td (Input Test PDF) Tj ET
BT /F1 12 Tf 50 200 Td (OpenAction should trigger popup) Tj ET
endstream
endobj
xref
0 6
0000000000 65535 f
0000000015 00000 n
0000000075 00000 n
0000000135 00000 n
0000002500 00000 n
0000002660 00000 n
trailer
<< /Size 6 /Root 1 0 R >>
startxref
2750
%%EOF