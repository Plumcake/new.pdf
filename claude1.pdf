%PDF-1.7
% activeDocs + execDialog Probe - iOS - March 2026
1 0 obj
<< /Type /Catalog
   /Pages 2 0 R
   /OpenAction 3 0 R
>>
endobj

2 0 obj
<< /Type /Pages
   /Kids [4 0 R]
   /Count 1
>>
endobj

3 0 obj
<< /Type /Action
   /S /JavaScript
   /JS (

        var results = [];

        // === 1. ACTIVE DOCS - other open documents ===
        results.push("=== ACTIVE DOCS ===");
        try {
          var docs = app.activeDocs;
          results.push("activeDocs type: " + typeof docs);
          results.push("activeDocs length: " + (docs ? docs.length : "null"));
          if (docs && docs.length > 0) {
            for (var i = 0; i < docs.length; i++) {
              try {
                results.push("doc[" + i + "] path: " + docs[i].path);
                results.push("doc[" + i + "] URL: " + docs[i].URL);
                results.push("doc[" + i + "] title: " + docs[i].info.Title);
              } catch(e) { results.push("doc[" + i + "]: " + e); }
            }
          }
        } catch(e) { results.push("activeDocs: " + e); }

        // === 2. FULLSCREEN OBJECT (real app.fs) ===
        results.push("=== FULLSCREEN ===");
        try {
          results.push("fs.isFullScreen: " + app.fs.isFullScreen);
          results.push("fs type: " + app.fs.toString());
        } catch(e) { results.push("fs: " + e); }

        // === 3. EXEC DIALOG - custom native dialog ===
        results.push("=== EXEC DIALOG ===");
        try {
          results.push("execDialog: " + typeof app.execDialog);
        } catch(e) { results.push("execDialog: " + e); }

        // === 4. PLUG-INS - reveals SDK components ===
        results.push("=== PLUGINS ===");
        try {
          var plugins = app.plugIns;
          results.push("plugIns length: " + plugins.length);
          for (var j = 0; j < plugins.length; j++) {
            try { results.push("plugin[" + j + "]: " + plugins[j].name + " v" + plugins[j].version); }
            catch(e) { results.push("plugin[" + j + "]: " + e); }
          }
        } catch(e) { results.push("plugIns: " + e); }

        // === 5. SECURITY OBJECT ===
        results.push("=== SECURITY ===");
        try {
          results.push("security type: " + typeof security);
          var secKeys = [];
          for (var k in security) { secKeys.push(k + ":" + typeof security[k]); }
          results.push("security keys: " + secKeys.join(", "));
        } catch(e) { results.push("security: " + e); }

        // === 6. DISCLOSED FLAG ===
        results.push("=== DISCLOSED ===");
        try {
          this.disclosed = true;
          var docs2 = app.activeDocs;
          results.push("after disclose - activeDocs: " + (docs2 ? docs2.length : "null"));
          if (docs2) {
            for (var m = 0; m < docs2.length; m++) {
              try { results.push("disclosed doc[" + m + "]: " + docs2[m].path); }
              catch(e) { results.push("disclosed doc[" + m + "]: " + e); }
            }
          }
        } catch(e) { results.push("disclosed: " + e); }

        app.alert(results.join("\\n"));

   )
>>
endobj

4 0 obj
<< /Type /Page
   /Parent 2 0 R
   /MediaBox [0 0 400 300]
   /Contents 5 0 R
   /Resources 
     /Font << /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica >> >>
   >>
>>
endobj

5 0 obj
<< /Length 90 >>
stream
BT /F1 14 Tf 50 250 Td (activeDocs Probe) Tj ET
BT /F1 12 Tf 50 220 Td (Check alert output) Tj ET
endstream
endobj

xref
0 6
0000000000 65535 f 
0000000015 00000 n 
0000000075 00000 n 
0000000135 00000 n 
0000002600 00000 n 
0000002760 00000 n 

trailer
<< /Size 6 /Root 1 0 R >>
startxref
2850
%%EOF